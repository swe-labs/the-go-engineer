    "projects-have-rubrics",
    "lessons-have-zero-magic-contract",
    "future-concepts-have-preview-only",
    "electives-do-not-block-core",
    "legacy-v2-is-not-authoritative",
    "starter-solution-parity",
    "no-broken-internal-links",
    "readme-required-headings-valid",
    "readme-level-purpose-valid",
    "readme-crossrefs-rendered-with-human-titles",
    "readme-no-generic-zero-magic-placeholders",
    "readme-no-stale-v2-section-labels",
    "readme-next-step-valid",
    "readme-module-map-generated-from-curriculum",
    "readme-project-rubric-present",
    "readme-assessment-evidence-present",
    "readme-preview-only-required-for-future-concepts",
    "readme-no-elective-blocks-core",
    "readme-no-broken-human-readable-links"
  ],
  "validation_commands": {
    "validate_schema": "go run ./internal/tools/curriculum validate-schema",
    "validate_graph": "go run ./internal/tools/curriculum validate-graph",
    "validate_lessons": "go run ./internal/tools/curriculum validate-lessons",
    "validate_prerequisite_closure": "go run ./internal/tools/curriculum validate-prerequisite-closure",
    "validate_project_binding": "go run ./internal/tools/curriculum validate-project-binding",
    "validate_no_placeholder_zm": "go run ./internal/tools/curriculum validate-no-placeholder-zm",
    "validate_assessment_completeness": "go run ./internal/tools/curriculum validate-assessment-completeness",
    "validate_unique_tags": "go run ./internal/tools/curriculum validate-unique-tags",
    "validate_crossrefs": "go run ./internal/tools/curriculum validate-crossrefs",
    "validate_all": "go run ./internal/tools/curriculum validate-all"
  }
