    "legacy_source": "curriculum/legacy/curriculum.v2.json"
  },
  "quality_gates": [
    "schema-valid",
    "graph-valid",
    "prerequisite-closure-valid",
    "project-binding-valid",
    "no-placeholder-zm",
    "assessment-completeness",
    "unique-tags",
    "crossrefs-valid",
    "no-orphan-core-items",
