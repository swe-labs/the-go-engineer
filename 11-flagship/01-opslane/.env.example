OPSLANE_ENV=development
OPSLANE_HTTP_ADDR=:8080
OPSLANE_LOG_LEVEL=info
OPSLANE_HTTP_READ_HEADER_TIMEOUT=5s
OPSLANE_HTTP_READ_TIMEOUT=10s
OPSLANE_HTTP_WRITE_TIMEOUT=15s
OPSLANE_HTTP_IDLE_TIMEOUT=60s
OPSLANE_HTTP_SHUTDOWN_TIMEOUT=20s
OPSLANE_DB_DSN=postgres://opslane:secretpassword@localhost:5432/opslane?sslmode=disable
OPSLANE_DB_MAX_OPEN_CONNS=4
OPSLANE_DB_MAX_IDLE_CONNS=2
OPSLANE_DB_CONN_MAX_IDLE_TIME=5m
OPSLANE_DB_CONN_MAX_LIFETIME=30m
