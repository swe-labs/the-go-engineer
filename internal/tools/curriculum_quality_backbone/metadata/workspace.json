  "generated_files": [],
  "policy": {
    "split_files_are_authoritative": true,
    "full_bundle_is_required": false,
    "full_bundle_purpose": "Debugging, export, review, and research convenience only.",
    "do_not_edit_generated_full_bundle_by_hand": true,
    "source_of_truth": "Split metadata files under metadata/ are authoritative. Generated bundles are review/export artifacts only.",
    "validation_tooling": "Metadata validation is now path-aware for metadata/, modules/, and electives/. The validate_all command no longer assumes a legacy curriculum/ directory."
  },
  "files": {
    "schema": "metadata/schema.v3.json",
    "core_path": "metadata/path.core.json",
    "electives": "metadata/path.electives.json",
    "projects": "metadata/projects.json",
    "assessments": "metadata/assessments.json",
    "crossrefs": "metadata/crossrefs.json",
    "concepts": "metadata/concepts.json",
    "failures": "metadata/failures.json",
    "readme_contracts": "metadata/readme.contracts.json",
    "migration": "metadata/migration.v2-to-v3.json",
    "legacy_source": "metadata/legacy/curriculum.v2.json"
  },
  "quality_gates": [
    "schema-valid",
    "graph-valid",
    "prerequisite-closure-valid",
    "project-binding-valid",
    "no-placeholder-zm",
    "assessment-completeness",
    "unique-tags",
    "crossrefs-valid",
    "no-orphan-core-items",
    "all-prerequisites-exist",
    "implemented-items-have-readmes",
    "implemented-items-have-run-or-test-command",
    "projects-have-rubrics",
    "lessons-have-zero-magic-contract",
    "future-concepts-have-preview-only",
    "electives-do-not-block-core",
    "legacy-v2-is-not-authoritative",
    "starter-solution-parity",
    "no-broken-internal-links",
    "readme-required-headings-valid",
    "readme-level-purpose-valid",
    "readme-crossrefs-rendered-with-human-titles",
    "readme-no-generic-zero-magic-placeholders",
    "readme-no-stale-v2-section-labels",
    "readme-next-step-valid",
    "readme-module-map-generated-from-curriculum",
    "readme-project-rubric-present",
    "readme-assessment-evidence-present",
    "readme-preview-only-required-for-future-concepts",
    "readme-no-elective-blocks-core",
    "readme-no-broken-human-readable-links",
    "project-graph-valid",
    "schema-version-3.1.0",
    "assessment-criteria-ids-match-module",
    "crossref-entity-domains-valid",
    "project-module-id-matches-reinforces-prefix",
    "zero-magic-semantic-quality"
  ],
  "validation_commands": {
    "metadata": "go run ./internal/tools/curriculum validate-metadata --root .",
    "repository": "go run ./internal/tools/curriculum validate-repository --root . --strict-repository",
    "all": "go run ./internal/tools/curriculum validate-all --root . --strict-repository"
  },
  "schema_version_policy": {
    "active_version": "3.1.0",
    "legacy_version": "3.0.0",
    "rule": "All new and edited files must use schema_version 3.1.0. Files at 3.0.0 are accepted for reads only. Validators must reject writing 3.1.0-only fields into 3.0.0 files.",
    "3.1.0_new_fields": {
      "projects": [
        "placement_anchor_item_id",
        "prerequisite_item_ids",
        "required_concepts",
        "reinforcement_targets"
      ],
      "document_types": [
        "concept_ownership_registry"
      ]
    }
  }
